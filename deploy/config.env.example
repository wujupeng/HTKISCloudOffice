# HTKIS Cloud Office 部署配置
# 复制此文件为 config.env 并填写实际值
# 注意：此文件包含敏感信息，已加入 .gitignore

# ====== 客户/项目信息 ======
CUSTOMER_NAME="your_customer"
APP_TITLE="Your-Cloud"
DOMAIN="****.yourdomain.com"

# ====== Debian 内网服务器 (Guacamole + frpc) ======
LAN_HOST="192.168.x.x"
LAN_SSH_PORT="22"
LAN_USER="****"
LAN_PASSWORD="****"
LAN_SUDO_PASSWORD="****"

# ====== Ubuntu 公网服务器 (nginx + frps) ======
WAN_HOST="x.x.x.x"
WAN_SSH_PORT="22"
WAN_ROOT_PASSWORD="****"

# ====== Windows RDP 目标 ======
RDP_HOST="192.168.x.x"
RDP_PORT="3389"
RDP_DOMAIN="****"
RDP_USERNAME="****"
RDP_PASSWORD="****"

# ====== frp 配置 ======
FRP_VERSION="0.65.0"
FRP_TOKEN="****"
FRPS_PORT="7001"
FRPS_DASHBOARD_PORT="7501"
FRPS_DASHBOARD_USER="admin"
FRPS_DASHBOARD_PASSWORD="****"
FRP_REMOTE_PORT="18080"

# ====== Guacamole 配置 ======
GUAC_ADMIN_USER="guacadmin"
GUAC_ADMIN_PASSWORD="****"
GUAC_TABLET_USER="tablet"
GUAC_TABLET_PASSWORD="****"
GUAC_DB_PASSWORD="****"
GUAC_PORT="8081"

# ====== Samba 配置 ======
SAMBA_WORKGROUP="WORKGROUP"
SAMBA_SHARE_PATH="/data/shares/public"
SAMBA_USER="****"
SAMBA_PASSWORD="****"

# ====== 邮箱验证服务 ======
SMTP_HOST="smtp.example.com"
SMTP_PORT="465"
SMTP_USER="noreply@example.com"
SMTP_PASSWORD="****"
SMTP_FROM="HTKIS Cloud Office <noreply@example.com>"
JWT_SECRET=""
ADMIN_USERNAMES="guacadmin"

# ====== 应用层数据库 ======
HTKIS_DB_PASSWORD="****"

# ====== 迁移配置 ======
OLD_SERVER_HOST="192.168.x.x"
NEW_SERVER_HOST="192.168.x.x"
