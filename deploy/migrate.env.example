# HTKIS Cloud Office 迁移配置
# 复制此文件为 migrate.env 并填写实际值
# 注意：此文件包含敏感信息，已加入 .gitignore

# ====== 旧服务器（源） ======
OLD_SERVER_HOST="192.168.x.x"
OLD_SERVER_SSH_PORT="22"
OLD_SERVER_USER="****"
OLD_SERVER_SUDO_PASSWORD="****"

# ====== 新服务器（目标） ======
NEW_SERVER_HOST="192.168.x.x"
NEW_SERVER_SSH_PORT="22"
NEW_SERVER_USER="****"
NEW_SERVER_SUDO_PASSWORD="****"

# ====== Guacamole 数据库 ======
GUAC_DB_PASSWORD="****"

# ====== frp 配置 ======
FRP_TOKEN="****"
FRPS_PORT="7001"
WAN_HOST="x.x.x.x"
FRP_REMOTE_PORT="18080"

# ====== Samba 配置 ======
SAMBA_WORKGROUP="WORKGROUP"
SAMBA_SHARE_PATH="/data/shares/public"

# ====== 迁移选项 ======
BACKUP_DIR="/tmp/htkis-migration-backup"
DRY_RUN="false"
STOP_OLD_SERVICES="true"