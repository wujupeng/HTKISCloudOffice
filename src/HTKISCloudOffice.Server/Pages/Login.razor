@page "/"
@page "/login"
@using Microsoft.AspNetCore.Components.Authorization

<div class="login-page">
    <div class="login-card">
        <div class="login-header">
            <h1>HTKIS Cloud Office</h1>
            <p>企业云办公平台</p>
        </div>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-error">@ErrorMessage</div>
        }

        <div class="login-form">
            <div class="form-group">
                <label for="username">用户名</label>
                <input type="text" id="username" @bind="Username" placeholder="请输入用户名" />
            </div>
            <div class="form-group">
                <label for="password">密码</label>
                <input type="password" id="password" @bind="Password" placeholder="请输入密码" />
            </div>
            <button class="btn-login" @onclick="HandleLogin" disabled="@IsLoading">
                @(IsLoading ? "登录中..." : "登 录")
            </button>
        </div>
    </div>
</div>

@if (ShowDeviceBindPrompt)
{
    <DeviceBindPrompt DeviceId="@CurrentDeviceId" DeviceName="@CurrentDeviceName"
                      OnConfirm="HandleDeviceBind" OnDismiss="() => ShowDeviceBindPrompt = false" />
}

@code {
    private string Username { get; set; } = "";
    private string Password { get; set; } = "";
    private string ErrorMessage { get; set; } = "";
    private bool IsLoading { get; set; }
    private bool ShowDeviceBindPrompt { get; set; }
    private string CurrentDeviceId { get; set; } = "";
    private string CurrentDeviceName { get; set; } = "";
    private bool IsAndroidDevice { get; set; }

    [Inject] private HttpClient Http { get; set; } = null!;
    [Inject] private NavigationManager Nav { get; set; } = null!;
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = null!;
    [Inject] private IHttpContextAccessor HttpContextAccessor { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(Nav.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        var device_token = query.GetValueOrDefault("device_token", "").ToString();
        var device_id = query.GetValueOrDefault("device_id", "").ToString();
        var platform = query.GetValueOrDefault("platform", "").ToString();

        IsAndroidDevice = platform.Equals("android", StringComparison.OrdinalIgnoreCase)
            || (HttpContextAccessor.HttpContext?.Request.Headers.TryGetValue("User-Agent", out var ua) == true
                && ua.ToString().Contains("Android", StringComparison.OrdinalIgnoreCase));

        if (!string.IsNullOrEmpty(device_token) && !string.IsNullOrEmpty(device_id))
        {
            CurrentDeviceId = device_id;
            CurrentDeviceName = IsAndroidDevice ? "Android设备" : "移动设备";
            await HandleDeviceAutoLogin(device_token, device_id);
        }
        else if (!string.IsNullOrEmpty(query.GetValueOrDefault("auto_login_token", "").ToString()))
        {
            await HandleAutoLogin(query.GetValueOrDefault("auto_login_token", "").ToString());
        }
    }

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(Username) || string.IsNullOrWhiteSpace(Password))
        {
            ErrorMessage = "请输入用户名和密码";
            return;
        }

        IsLoading = true;
        ErrorMessage = "";

        try
        {
            var response = await Http.PostAsJsonAsync("/api/v1/auth/login", new { username = Username, password = Password });
            if (response.IsSuccessStatusCode)
            {
                if (IsAndroidDevice)
                {
                    CurrentDeviceId = Guid.NewGuid().ToString();
                    CurrentDeviceName = "Android设备";
                    ShowDeviceBindPrompt = true;
                }
                else
                {
                    Nav.NavigateTo("/portal", forceLoad: true);
                }
            }
            else
            {
                ErrorMessage = "用户名或密码错误";
            }
        }
        catch
        {
            ErrorMessage = "网络错误，请稍后重试";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task HandleAutoLogin(string token)
    {
        try
        {
            var response = await Http.PostAsJsonAsync("/api/v1/auth/auto-login", new { auto_login_token = token });
            if (response.IsSuccessStatusCode)
            {
                Nav.NavigateTo("/portal", forceLoad: true);
            }
        }
        catch
        {
            ErrorMessage = "自动登录失败，请手动登录";
        }
    }

    private async Task HandleDeviceAutoLogin(string device_token, string device_id)
    {
        try
        {
            var response = await Http.PostAsJsonAsync("/api/v1/auth/device-login", new { device_token, device_id });
            if (response.IsSuccessStatusCode)
            {
                Nav.NavigateTo("/portal", forceLoad: true);
            }
            else
            {
                ErrorMessage = "设备自动登录失败，请手动登录";
            }
        }
        catch
        {
            ErrorMessage = "设备自动登录失败，请手动登录";
        }
    }

    private async Task HandleDeviceBind()
    {
        try
        {
            var response = await Http.PostAsJsonAsync("/api/v1/auth/device-bind", new { device_id = CurrentDeviceId, device_name = CurrentDeviceName });
            ShowDeviceBindPrompt = false;
            Nav.NavigateTo("/portal", forceLoad: true);
        }
        catch
        {
            ShowDeviceBindPrompt = false;
            Nav.NavigateTo("/portal", forceLoad: true);
        }
    }
}
